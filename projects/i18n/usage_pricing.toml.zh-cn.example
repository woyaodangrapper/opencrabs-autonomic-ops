  { prefix = "o3-mini",            input_per_m = 1.10,  output_per_m = 4.40  },
  { prefix = "o3",                 input_per_m = 10.0,  output_per_m = 40.0  },
  { prefix = "o1-mini",            input_per_m = 1.10,  output_per_m = 4.40  },
