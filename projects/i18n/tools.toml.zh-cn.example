# OpenCrabs 动态工具
# 复制到 ~/.opencrabs/tools.toml 并按需自定义。
#
# 这些是在运行时定义、可由代理自主调用的工具。
# 与 commands.toml（用户触发的斜杠命令）不同，这些工具会出现在
# LLM 的工具列表中，由代理决定何时使用。
#
# 修改会热重载，无需重启。
# 代理也可以通过 `tool_manage` 元工具管理工具。

# --- HTTP 工具 ---

[[tools]]
name = "health_check"
description = "Check if a service endpoint is healthy"
executor = "http"
method = "GET"
url = "https://{{host}}/health"
timeout_secs = 10
requires_approval = false
enabled = true

[[tools.params]]
name = "host"
type = "string"
description = "Hostname or IP to check (e.g. api.example.com)"
required = true

[[tools]]
name = "github_api"
description = "Query the GitHub REST API"
executor = "http"
method = "GET"
url = "https://api.github.com/{{endpoint}}"
headers = { "Authorization" = "Bearer {{token}}", "Accept" = "application/vnd.github+json" }
timeout_secs = 15
requires_approval = true
enabled = true

[[tools.params]]
name = "endpoint"
type = "string"
description = "API path (e.g. repos/owner/repo/issues)"
required = true

[[tools.params]]
name = "token"
type = "string"
description = "GitHub personal access token"
required = true

[[tools]]
name = "webhook_notify"
description = "Send a notification to a webhook URL"
executor = "http"
method = "POST"
url = "{{webhook_url}}"
headers = { "Content-Type" = "application/json" }
timeout_secs = 10
requires_approval = true
enabled = false

[[tools.params]]
name = "webhook_url"
type = "string"
description = "Full webhook URL"
required = true

# --- Shell 工具 ---

[[tools]]
name = "disk_usage"
description = "Show disk usage for a directory"
executor = "shell"
command = "du -sh {{path}} 2>/dev/null || echo 'Path not found'"
timeout_secs = 10
requires_approval = false
enabled = true

[[tools.params]]
name = "path"
type = "string"
description = "Directory path to check"
required = true

[[tools]]
name = "docker_status"
description = "List running Docker containers"
executor = "shell"
command = "docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
timeout_secs = 10
requires_approval = false
enabled = true

[[tools]]
name = "git_log_summary"
description = "Show recent git commits in a repository"
executor = "shell"
command = "cd {{repo_path}} && git log --oneline -{{count}}"
timeout_secs = 10
requires_approval = false
enabled = true

[[tools.params]]
name = "repo_path"
type = "string"
description = "Path to the git repository"
required = true

[[tools.params]]
name = "count"
type = "string"
description = "Number of commits to show"
required = false

[[tools]]
name = "deploy_staging"
description = "Deploy a branch to the staging environment"
executor = "shell"
command = "cd ~/project && ./deploy.sh {{branch}} staging"
timeout_secs = 120
requires_approval = true
enabled = false

[[tools.params]]
name = "branch"
type = "string"
description = "Git branch to deploy"
required = true

# --- 内置 RSI 工具（无需配置） ---
#
# OpenCrabs 内置 3 个递归自我改进工具，开箱即用，
# 无需在 tools.toml 中添加条目：
#
#   feedback_record   记录观察结果（工具结果、用户纠正、模式）
#   feedback_analyze  查询反馈账本（摘要、工具统计、近期记录、失败）
#   self_improve      提议/应用 brain 文件变更（需要人工批准）
#
# 这些是编译内置工具，不是动态工具。它们会自动出现在 LLM 工具列表中。
# 工具执行会自动记录到反馈账本；当代理发现值得跟踪的模式时，
# 也会手动调用 feedback_record/feedback_analyze。

# --- 字段参考 ---
#
# name              （必需）工具名称，代理用它来调用工具
# description       （必需）工具的作用，会展示给 LLM
# executor          （必需）"http" 或 "shell"
# enabled           （可选）true/false，默认：true
# requires_approval （可选）true/false，默认：true
# timeout_secs      （可选）执行超时时间，默认：30
# params            （可选）参数定义（name、type、description、required）
#
# HTTP 专用：
#   method         "GET"、"POST"、"PUT"、"DELETE" 等
#   url            带有 {{param}} 模板变量的 URL
#   headers        键值映射，支持 {{param}} 替换
#
# Shell 专用：
#   command        带有 {{param}} 模板变量的 Shell 命令
